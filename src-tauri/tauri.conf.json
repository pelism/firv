{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "firv",
  "version": "1.0.0-alpha",
  "identifier": "com.pelism.firv",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 800,
        "height": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "deb",
      "appimage"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/pelism/firv/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBN0FBNzgzNTA1MzEzMzcKUldRM0UxTlFnNmQ2bXVQTGdNT3p0a09vQXVKSUJSK2d5V3oxRThaNjYyTGMzTWFLeUtIQlN2L1gK"
    }
  }
}
